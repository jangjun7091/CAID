# Copy this file to .env and fill in your values.
# CAID reads these via python-dotenv (loaded at startup).

# ---------------------------------------------------------------------------
# Local LLM (Ollama) — recommended, no API key required
# ---------------------------------------------------------------------------
CAID_USE_LOCAL_LLM=true
LLM_MODEL=qwen2.5-coder:7b
LLM_BASE_URL=http://localhost:11434/v1

# ---------------------------------------------------------------------------
# Anthropic API — only needed when CAID_USE_LOCAL_LLM is not set
# ---------------------------------------------------------------------------
# ANTHROPIC_API_KEY=sk-ant-...
# CAID_MODEL=claude-sonnet-4-6
# CAID_FAST_MODEL=claude-haiku-4-5-20251001

# ---------------------------------------------------------------------------
# General settings
# ---------------------------------------------------------------------------
# CAID_OUTPUT_DIR=./output
# CAID_MAX_ITERATIONS=5
