# Copy this file to .env and fill in your values.
# CAID reads these via pydantic-settings.

# Required: Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override default model IDs
# CAID_MODEL=claude-sonnet-4-6
# CAID_FAST_MODEL=claude-haiku-4-5-20251001

# Optional: output directory for STEP/STL files (default: ./output)
# CAID_OUTPUT_DIR=./output

# Optional: max Design-Critique-Refine iterations per component (default: 5)
# CAID_MAX_ITERATIONS=5
