## Example — safe mounting bracket pattern
```python
import cadquery as cq

# Parameters
base_length_mm  = 80.0
base_width_mm   = 50.0
base_thick_mm   = 6.0
wall_height_mm  = 40.0
wall_thick_mm   = 6.0
hole_diam_mm    = 5.5
fillet_r_mm     = 2.0

# Base plate
base = cq.Workplane("XY").box(base_length_mm, base_width_mm, base_thick_mm)

# Vertical wall — start a fresh workplane at known Z rather than using |Z
wall = (
    cq.Workplane("XY", origin=(0, 0, base_thick_mm))
    .rect(wall_thick_mm, base_width_mm)
    .extrude(wall_height_mm)
    .translate((-base_length_mm / 2 + wall_thick_mm / 2, 0, 0))
)

# Union and add mounting holes using directional selector (safe)
result = (
    base.union(wall)
    .faces(">Z").workplane()          # safe: single topmost face
    .pushPoints([
        ( base_length_mm / 2 - 10, -base_width_mm / 2 + 10),
        ( base_length_mm / 2 - 10,  base_width_mm / 2 - 10),
        (-base_length_mm / 2 + 10, -base_width_mm / 2 + 10),
        (-base_length_mm / 2 + 10,  base_width_mm / 2 - 10),
    ])
    .hole(hole_diam_mm)
    .edges("|Z").fillet(fillet_r_mm)
)
```
